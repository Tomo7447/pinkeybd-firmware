#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#define ZMK_POINTING_DEFAULT_SCRL_VAL 80

&mt {
    flavor = "tap-preferred";
    tapping-term-ms = <250>;
};

&lt { tapping-term-ms = <250>; };

/ {
    behaviors {
        rot_kp: sensor_rotate_kp {
            compatible = "zmk,behavior-sensor-rotate-var";
            #sensor-binding-cells = <2>;
            bindings = <&kp>, <&kp>;
        };

        minus_single: minus_single {
            compatible = "zmk,behavior-mod-morph";
            label = "MINUS_SINGLE";
            bindings = <&kp MINUS>, <&kp LS(N7)>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        slash_double: slash_double {
            compatible = "zmk,behavior-mod-morph";
            label = "SLASH_DOUBLE";
            bindings = <&kp SLASH>, <&kp AT>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        period_exclamation: period_exclamation {
            compatible = "zmk,behavior-mod-morph";
            label = "PERIOD_EXCLAMATION";
            bindings = <&kp PERIOD>, <&kp EXCLAMATION>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };

        comma_question: comma_question {
            compatible = "zmk,behavior-mod-morph";
            label = "COMMA_QUESTION";
            bindings = <&kp COMMA>, <&kp QUESTION>;

            #binding-cells = <0>;
            mods = <(MOD_LSFT)>;
        };
    };

    combos {
        compatible = "zmk,combos";

        left_kakko {
            bindings = <&kp LS(N8)>;
            key-positions = <2 3>;
            layers = <0 2 1>;
        };

        right_kakko {
            bindings = <&kp LS(N9)>;
            key-positions = <3 4>;
            layers = <0 1 2>;
        };

        Left_kagi {
            bindings = <&kp RIGHT_BRACKET>;
            key-positions = <13 14>;
            layers = <0 1 2>;
        };

        Right_kagi {
            bindings = <&kp NUHS>;
            key-positions = <15 14>;
            layers = <0 2 1>;
        };

        Syounari {
            bindings = <&kp LS(COMMA)>;
            key-positions = <24 25>;
            layers = <0 2 1>;
        };

        Dainari {
            bindings = <&kp LS(DOT)>;
            key-positions = <25 26>;
            layers = <0 1 2>;
        };

        Left_boot_reset {
            bindings = <&bootloader>;
            key-positions = <0 1 2 3>;
            layers = <0>;
        };

        Right_boot_reset {
            bindings = <&bootloader>;
            key-positions = <10 9 8 7>;
            layers = <0>;
        };
    };

    behaviors {
    };

    keymap {
        compatible = "zmk,keymap";

        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |        /       |       ,       |       .       |      -        |      ;       |    ESC         |                   |           |       L      |       R       |       D       |       Y       |      P      |
        // |        A       |       O       |       E       |      I        |      U       |    SCROLLLOCK  |                   |           |       G      |       N       |       T       |       S       |      K      |
        // |        X       |       C       |       V       |      W        |      Q       |    TAB         |                   |     F     |       J      |       H       |       M       |       B       |      Z      |
        // |    L_SHIFT     |               |               |   LOWER / Jp  |    Space     |    LEFT_WIN    |                   |  R_SHIFT  |      ENTER   |  LOWER2 / Ja  |               |               |   FUN_L     |
        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        default_layer {
            bindings = <
&kp Q                 &kp W            &kp E      &kp R  &kp T          &mt LG(PERIOD) F7  &kp Y      &kp U      &kp I             &kp O                &kp P
&mt LEFT_ALT A        &kp S            &kp D      &kp F  &kp G          &none              &kp H      &kp J      &kp K             &kp L                &minus_single
&mt LEFT_SHIFT Z      &kp X            &kp C      &kp V  &kp B          &mt LS(LG(S)) F10  &kp N      &kp M      &comma_question   &period_exclamation  &slash_double
&mt LEFT_CONTROL TAB  &lt 3 BACKSPACE  &kp SPACE  &mo 1  &kp LC(SPACE)  &mkp LCLK          &kp ENTER  &mkp RCLK  &mt LG(H) DELETE
            >;

            sensor-bindings = <&rot_kp DOWN_ARROW UP_ARROW>;
        };

        // ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    /           |       ,       |       END     |     （        |      ”        |    PAUSE_BREAK|                  |            |      （       |       ）     |        ↑      |        [      |      ]      |
        // |    HOME        |       C_SAVE  |       END     |       ）      |       U       |    SCROLLLOCK |                  |            |   Backspace   |       ←      |        ↓      |        →      |     DEL     |
        // |    UNDO        |       CUT     |       COPY    |       PASTE   |       Q       |    TAB        |                  |   PSCRN    |    ' / "      |    = / +     |    \ / |      |    ` / ~      |    INS      |
        // |    L_SHIFT     |               |               |       none    |    SPACE      |    LALT       |                  |   RSHIFT   |   ENTER       |       FUN_L  |               |               |    RCTRL    |
        // ----------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        symbol_and_number_layer {
            bindings = <
&none  &kp LEFT_BRACKET  &kp HASH     &kp SINGLE_QUOTE  &none   &none      &kp N7        &kp N8        &kp N9             &kp LS(MINUS)            &kp LS(SEMICOLON)
&none  &kp LS(NUMBER_6)  &kp PERCENT  &kp SEMI          &none   &none      &kp NUMBER_4  &kp N5        &kp NUMBER_6       &kp LS(INTERNATIONAL_1)  &kp MINUS
&none  &none             &none        &none             &none   &none      &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3       &kp PERIOD               &kp SLASH
&none  &kp BACKSPACE     &trans       &trans            &kp N0  &mkp LCLK  &kp ENTER     &mkp RCLK     &kp DOUBLE_QUOTES
            >;

            sensor-bindings = <&rot_kp PAGE_DOWN PAGE_UP>;
        };

        // -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    /           |       ,        |       END     |       {       |       ’      |    ESC        |                  |            |      L      |      R         |    PG_UP      |     {       |      }      |
        // |    HOME        |       C_SAVE   |       END     |       }       |       U      |    LCTRL      |                  |            |  Backspace  |    HOME        |    PG_DN      |    END      |    DEL      |
        // |    UNDO        |       CUT      |       COPY    |       PASTE   |       Q      |    TAB        |                  |      F     |    ' / "    |    = / +       |    \ / |      |    ` / ~    |    INS      |
        // |    L_SHIFT     |                |               |       BT_L    |      SPACE   |    LALT       |                  |   ENTER    |    none     |   R_SHIFT      |               |             |   R_SHIFT   |
        // -------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Not_in_use {
            bindings = <
&none  &none   &none   &none   &none   &none          &kp N7        &kp N8        &kp N9                 &kp LS(MINUS)            &kp LS(SEMICOLON)
&none  &none   &none   &none   &none   &none          &kp NUMBER_4  &kp N5        &kp NUMBER_6           &kp LS(INTERNATIONAL_1)  &kp MINUS
&none  &none   &none   &none   &none   &none          &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3           &kp PERIOD               &kp SLASH
&none  &trans  &trans  &trans  &kp N0  &kp BACKSPACE  &trans        &none         &mt DEL DOUBLE_QUOTES
            >;

            sensor-bindings = <&rot_kp DOWN UP_ARROW>;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |        1       |      2        |       3       |       4       |       5       |    ESC        |               |            |      6       |      7        |       8       |       9       |       0       |
        // |        !       |      @        |       #       |       $       |       %       |    none       |               |            |      ^       |      &        |       *       |       (       |       )       | 
        // |        F1      |     F2        |     F3        |       F4      |       F5      |    TAB        |               |     F11    |    ' / "     |    = / +      |    \ / |      |    ` / ~      |       INS     |
        // |    L_SHIFT     |               |               | En / LOWER    |    Space      |    LSIHT      |               |   R_SHIFT  |      ENTER   |     none      |               |               |       R_SHIFT |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Arrow_layer {
            bindings = <
&kp C_MUTE       &none   &kp ESCAPE  &none   &none           &none          &none         &none        &none  &none  &kp HOME
&kp C_VOL_DN     &none   &none       &none   &none           &none          &kp UP_ARROW  &none        &none  &none  &kp END
&kp C_VOLUME_UP  &none   &none       &none   &none           &none          &kp DOWN      &kp RIGHT    &none  &none  &none
&none            &trans  &mo 5       &trans  &kp LEFT_ARROW  &kp PAGE_DOWN  &trans        &kp PAGE_UP  &none
            >;

            sensor-bindings = <&rot_kp PAGE_DOWN PG_UP>;
        };

        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |     F1      |     F2     |     F3     |     F4     |    F5      |    none    |                |            |    F6      |    F7      |    F8      |    F9       |     F10     |
        // |     F11     |     F12    |     F13    |     F14    |    F15     |    none    |                |   none     |    F16     |    F17     |    F18     |    F19      |     F20     |
        // |     none    |    none    |    none    |    none    |   none     |    none    |                |   none     |    none    |    none    |    none    |    none     |     none    |
        // |     L_SHIFT |    none    |    none    |    none    |   none     |    none    |                |   none     |    none    |    none    |    none    |    none     |     R_SHIFT |
        // ---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Func_layer {
            bindings = <
&kp F1      &kp F2   &kp F3   &kp F4   &kp F5   &none  &kp F6   &kp F7   &kp F8      &kp F9   &none
&kp F11     &kp F12  &kp F13  &kp F14  &kp F15  &none  &kp F16  &kp F17  &kp F18     &kp F19  &none
&none       &none    &none    &none    &none    &none  &none    &none    &none       &none    &none
&kp LSHIFT  &none    &none    &none    &none    &none  &none    &none    &kp RSHIFT
            >;
        };

        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |            |    none    |    none    |    none    |   none     |    none    |
        // |  BT_SEL 0  |  BT_SEL 1  |  BT_SEL 2  |  BT_SEL 3  |   none     |    none    |                  |            |    none    |    none    |    none    |   BT_CLR   | BT_CLR_ALL |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |    none    |    none    |   BT_PRV   |    none    |   BT_NXT   |    none    |
        // |    none    |    none    |    none    |    none    |   none     |    none    |                  |    none    |    none    |    none    |    none    |   none     |    none    |
        // --------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

        Bt_layer {
            bindings = <
&none  &none  &none  &none  &none         &none  &none         &none         &none  &none  &none
&none  &none  &none  &none  &none         &none  &none         &none         &none  &none  &none
&none  &none  &none  &none  &none         &none  &bt BT_SEL 1  &bt BT_SEL 2  &none  &none  &none
&none  &none  &none  &none  &bt BT_SEL 0  &none  &none         &none         &none
            >;
        };
    };
};
